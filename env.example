# ============================================================================
# Yquoter Environment Configuration
# ============================================================================
# Copy this file to .env and fill in your API keys.
# cp env.example .env
# ============================================================================

# ---------------------------------------------------------------------------
# Data Source: Tushare (optional)
# Required only if you want to use Tushare as a data source.
# ---------------------------------------------------------------------------
# TUSHARE_TOKEN=your_tushare_token_here

# ---------------------------------------------------------------------------
# LLM Provider: AI-Powered Analysis (optional)
# Configure at least one to enable intelligent market analysis in reports.
# Yquoter auto-detects configured providers and falls back if one fails.
# Priority order: DeepSeek > OpenAI > Qwen > Kimi > Claude > Gemini
# ---------------------------------------------------------------------------

# ★ DeepSeek (Recommended - best price/performance)
DEEPSEEK_API_KEY=sk-your_deepseek_api_key_here
DEEPSEEK_API_BASE=https://api.deepseek.com

# OpenAI / ChatGPT
# OPENAI_API_KEY=sk-your_openai_api_key_here
# OPENAI_API_BASE=https://api.openai.com

# Alibaba Qwen (Tongyi Qianwen)
# Note: Uses OpenAI-compatible endpoint via dashscope
# QWEN_API_KEY=sk-your_qwen_api_key_here
# QWEN_API_BASE=https://dashscope.aliyuncs.com/compatible-mode/v1

# Moonshot Kimi
# KIMI_API_KEY=sk-your_kimi_api_key_here
# KIMI_API_BASE=https://api.moonshot.cn/v1

# Anthropic Claude
# CLAUDE_API_KEY=sk-ant-your_claude_api_key_here
# CLAUDE_API_BASE=https://api.anthropic.com

# Google Gemini
# GEMINI_API_KEY=your_gemini_api_key_here
# GEMINI_API_BASE=https://generativelanguage.googleapis.com/v1beta

# ---------------------------------------------------------------------------
# Custom Model Override (advanced)
# Uncomment to specify a custom model for a provider.
# ---------------------------------------------------------------------------
# DEEPSEEK_MODEL=deepseek-chat
# OPENAI_MODEL=gpt-4o-mini
# QWEN_MODEL=qwen-plus
# GEMINI_MODEL=gemini-1.5-flash

# ---------------------------------------------------------------------------
# Cache & Log Paths (optional)
# ---------------------------------------------------------------------------
# CACHE_ROOT=.cache
# LOG_ROOT=.log
